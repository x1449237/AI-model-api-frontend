<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Prompt input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/cluster_prompt_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:boxBackgroundColor="@color/colorSurfaceVariant"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:hintTextColor="@color/colorTextHint"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/cluster_prompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:hint="输入问题，将同时发送给已选模型..."
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextHint"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Status bar -->
    <LinearLayout
        android:id="@+id/cluster_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/status_text"
            android:text="请至少选择 2 个模型"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_run_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="集群对比"
            android:textSize="13sp"
            android:textColor="@color/colorTextWhite"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="18dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Model selection area -->
    <LinearLayout
        android:id="@+id/cluster_select_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:text="选择模型（至少2个，最多5个）"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/cluster_model_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- Results area -->
    <ScrollView
        android:id="@+id/cluster_results_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/cluster_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <!-- Progress -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ProgressBar
            android:id="@+id/cluster_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/colorPrimary" />

        <TextView
            android:id="@+id/cluster_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
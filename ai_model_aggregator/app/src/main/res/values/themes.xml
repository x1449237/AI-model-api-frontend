<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AIAggregator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4A90D9</item>
        <item name="colorPrimaryVariant">#3A7BC8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#4A90D9</item>
        <item name="colorSecondaryVariant">#3A7BC8</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">#F5F5F5</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A1A</item>
        <item name="colorSurfaceVariant">#E8E8E8</item>
        <item name="colorOnSurfaceVariant">#666666</item>
        <item name="colorError">#B00020</item>
        <item name="colorOnError">#FFFFFF</item>
        <item name="android:statusBarColor">#F5F5F5</item>
        <item name="android:navigationBarColor">#F5F5F5</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="bottomNavigationStyle">@style/Widget.AIAggregator.BottomNavigationView</item>
        <item name="tabStyle">@style/Widget.AIAggregator.TabLayout</item>
    </style>

    <style name="Widget.AIAggregator.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">#FFFFFF</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
    </style>

    <style name="Widget.AIAggregator.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">#FFFFFF</item>
        <item name="tabTextColor">#666666</item>
        <item name="tabSelectedTextColor">#4A90D9</item>
        <item name="tabIndicatorColor">#4A90D9</item>
    </style>
</resources>
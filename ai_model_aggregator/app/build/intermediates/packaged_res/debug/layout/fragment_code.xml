<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Language selector chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/colorSurface"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/lang_chips"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Model selector row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/colorSurface"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_model"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="选择模型"
            android:textSize="13sp"
            android:textColor="@color/colorTextPrimary"
            app:backgroundTint="@color/colorSurfaceVariant"
            app:rippleColor="@color/colorPrimary"
            app:cornerRadius="18dp" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/selected_model_text"
            android:text="未选择模型"
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary" />
    </LinearLayout>

    <!-- Prompt input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:boxBackgroundColor="@color/colorSurfaceVariant"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:hintTextColor="@color/colorTextHint"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/code_desc_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:hint="描述你想要生成的代码..."
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextHint"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Generate button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_generate"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:text="生成代码"
        android:textSize="14sp"
        android:textColor="@color/colorTextWhite"
        app:backgroundTint="@color/colorPrimary"
        app:cornerRadius="12dp" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:visibility="gone"
        android:indeterminateTint="@color/colorPrimary"
        style="?android:attr/progressBarStyleHorizontal" />

    <!-- Result header -->
    <LinearLayout
        android:id="@+id/result_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:visibility="gone">

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="复制"
            android:textSize="12sp"
            android:textColor="@color/colorPrimary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_export"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="导出"
            android:textSize="12sp"
            android:textColor="@color/colorPrimary" />
    </LinearLayout>

    <!-- Code output area -->
    <ScrollView
        android:id="@+id/code_output_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:background="@color/colorCodeBg">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/code_output"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:textColor="@color/colorCodeText"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:lineSpacingExtra="4dp" />
        </HorizontalScrollView>
    </ScrollView>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;/&gt;"
            android:textSize="48sp"
            android:textColor="@color/colorTextSecondary"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="选择模型和语言，输入需求描述\n点击生成代码"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />
    </LinearLayout>
</LinearLayout>
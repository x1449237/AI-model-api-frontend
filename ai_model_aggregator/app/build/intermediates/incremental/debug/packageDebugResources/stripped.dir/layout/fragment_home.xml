<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Top bar: conversation title, buttons, model selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorBackground"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp">

        <!-- Conversation title -->
        <TextView
            android:id="@+id/conversation_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="新对话"
            android:textSize="14sp"
            android:textColor="@color/colorTextPrimary"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingHorizontal="4dp" />

        <!-- New chat button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_new_chat"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="新建对话"
            app:icon="@drawable/ic_add"
            app:iconSize="18dp"
            app:iconTint="@color/colorTextSecondary"
            app:rippleColor="@color/colorSurfaceVariant" />

        <!-- History button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_history"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:contentDescription="对话历史"
            app:icon="@drawable/ic_history"
            app:iconSize="18dp"
            app:iconTint="@color/colorTextSecondary"
            app:rippleColor="@color/colorSurfaceVariant" />

        <!-- Model selector button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_model_selector"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingHorizontal="8dp"
            android:text="选择模型"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:ellipsize="end"
            app:icon="@android:drawable/arrow_down_float"
            app:iconGravity="end"
            app:iconSize="14dp"
            app:iconTint="@color/colorTextSecondary"
            app:rippleColor="@color/colorPrimary" />
    </LinearLayout>

    <!-- Cluster mode bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/colorBackground"
        android:paddingHorizontal="12dp"
        android:paddingVertical="2dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="集群模式"
            android:textSize="13sp"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginEnd="4dp" />

        <Switch
            android:id="@+id/switch_cluster_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Cluster mode model selection area (hidden by default) -->
    <LinearLayout
        android:id="@+id/cluster_mode_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="选择要对比的模型（至少2个）："
            android:textSize="12sp"
            android:textColor="@color/colorTextSecondary"
            android:paddingBottom="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/cluster_model_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Chat area -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingVertical="8dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Bottom input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/colorSurface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_params"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_tune"
            app:iconSize="20dp"
            app:iconTint="@color/colorTextSecondary"
            app:rippleColor="@color/colorSurfaceVariant"
            android:contentDescription="参数" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_templates"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_template"
            app:iconSize="20dp"
            app:iconTint="@color/colorTextSecondary"
            app:rippleColor="@color/colorSurfaceVariant"
            android:contentDescription="模板" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/colorInputBg"
            app:strokeColor="@color/colorInputStroke"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/input_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:hint="输入消息..."
                android:textColorHint="@color/colorTextHint"
                android:textColor="@color/colorTextPrimary"
                android:textSize="14sp"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:scrollbars="vertical" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Token counter -->
        <TextView
            android:id="@+id/token_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="11sp"
            android:textColor="@color/colorTokenCounter"
            android:layout_marginEnd="4dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_send"
            app:iconSize="22dp"
            app:iconTint="@color/colorSendButton"
            app:rippleColor="@color/colorSurfaceVariant"
            android:contentDescription="发送" />
    </LinearLayout>

    <!-- Hidden params panel (kept for backward compat) -->
    <LinearLayout
        android:id="@+id/params_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorSurface"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Temperature: " android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/temperature_slider" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="100" android:progress="70" android:progressTint="@color/colorPrimary" android:thumbTint="@color/colorPrimary" android:progressBackgroundTint="@color/colorProgressTrack" />
            <TextView android:id="@+id/temperature_value" android:text="0.70" android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="40dp" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Top-P: " android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/topp_slider" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="100" android:progress="90" android:progressTint="@color/colorPrimary" android:thumbTint="@color/colorPrimary" android:progressBackgroundTint="@color/colorProgressTrack" />
            <TextView android:id="@+id/topp_value" android:text="0.90" android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="40dp" android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Max Tokens: " android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            <SeekBar android:id="@+id/max_tokens_slider" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="8192" android:progress="2048" android:progressTint="@color/colorPrimary" android:thumbTint="@color/colorPrimary" android:progressBackgroundTint="@color/colorProgressTrack" />
            <TextView android:id="@+id/max_tokens_value" android:text="2048" android:textSize="12sp" android:textColor="@color/colorTextSecondary" android:layout_width="40dp" android:layout_height="wrap_content" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>